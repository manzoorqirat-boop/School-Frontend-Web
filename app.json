{
  "expo": {
    "name": "QMSoft School",
    "slug": "qmschool",
    "scheme": "qmschool",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#6D3CF0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qmsofts.school"
    },
    "android": {
      "package": "com.qmsofts.school",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiBase": "https://schoolnet-production-fedc.up.railway.app"
    },
    "owner": "schooldotnet",
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    }
  }
}
